# apa
PORT=5000

# db
DB_HOST=localhost
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_NAME=event_ticketing
DB_TIMEZONE="Asia/Jakarta"
DB_CONNECTION_TIMEOUT=10s
DB_MAX_OPEN_CONNS=30
DB_MAX_IDLE_CONNS=30
DB_CONN_MAX_LIFETIME=20m
DB_CONN_MAX_IDLETIME=10m

# redis
ENABLE_CACHING=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_NUMBER=3
REDIS_MAX_CONN_SIZE=30
REDIS_IDLE_CONN_SIZE=10
REDIS_CONN_LIFETIME=15m

# otlp
OTLP_SERVICE_NAME=go-event-ticketing
OTLP_ENDPOINT=localhost
OTLP_PORT=4317

# http server
HTTP_SERVER_READ_HEADER_TIMEOUT=3s
HTTP_SERVER_READ_TIMEOUT=5s
HTTP_SERVER_WRITE_TIMEOUT=8s
HTTP_SERVER_IDLE_TIMEOUT=30s